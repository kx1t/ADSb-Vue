# ADSb-Vue configuration — copy to ".env" and edit as needed.
#
# server.py auto-loads a .env in this directory (real environment variables and
# docker-compose `environment:` entries take precedence over this file).
# For Docker, either keep using compose's `environment:` block or add
# `env_file: .env` to the service.

# Base URL of your tar1090 / Ultrafeeder instance.
# Use http://127.0.0.1 when running on the same host as the feeder.
ADSB_ULTRAFEEDER=http://127.0.0.1

# Port the viewer listens on.
ADSB_PORT=24556

# Receiver location. Leave unset to auto-detect from tar1090's
# /data/receiver.json (recommended).
#ADSB_RECV_LAT=44.0
#ADSB_RECV_LON=-93.0

# How many newest history chunks to read (0 = all available history).
# More chunks = wider coverage envelope but slower first load.
ADSB_MAX_CHUNKS=48

# Seconds to cache parsed observations before a rebuild.
ADSB_CACHE_SECS=120

# De-dup resolution: coarse on purpose (this is a coverage map, not a replay).
ADSB_CELL_NM=1.5        # horizontal grid cell size, nautical miles
ADSB_ALT_BIN_FT=1000    # altitude bin size, feet

# Sanity/analysis thresholds.
ADSB_MAX_RANGE_NM=400   # discard positions farther than this (bad data / MLAT)
ADSB_LOW_ALT_FT=10000   # "low altitude" cutoff for the low-altitude range stat

# Parallel chunk downloads. Bigger helps a lot when the feeder is remote /
# high-latency; on the same host it's network-cheap so this barely matters.
# Set to 1 for the old serial behaviour.
ADSB_FETCH_WORKERS=8
